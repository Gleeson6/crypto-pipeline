# Binance TESTNET API Keys
# Get yours free at: https://testnet.binance.vision
# Click "Log in with GitHub" → Generate HMAC_SHA256 Key
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# Trade settings
TRADE_SYMBOL=BTCUSDT
TRADE_QUANTITY=0.001        # BTC per trade (≈ $60–70 on testnet)
MAX_OPEN_TRADES=1           # Only 1 position at a time
